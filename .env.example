# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# TikTok Shop API (셀러센터)
TIKTOK_SHOP_APP_KEY=your-app-key
TIKTOK_SHOP_APP_SECRET=your-app-secret
TIKTOK_SHOP_ID=your-shop-id
TIKTOK_SHOP_ACCESS_TOKEN=your-access-token

# Crawler — "apify" (기본) 또는 "self-hosted"
CRAWLER_TYPE=apify

# Apify (CRAWLER_TYPE=apify일 때)
APIFY_API_TOKEN=your-apify-token

# Self-hosted Crawler (CRAWLER_TYPE=self-hosted일 때)
# CRAWLER_BASE_URL=http://crawler.internal:8080
# CRAWLER_API_KEY=your-crawler-key

# Shipping Tracker — "aftership" (기본) 또는 "self-hosted"
SHIPPING_TRACKER=aftership
AFTERSHIP_API_KEY=your-aftership-key

# Self-hosted Shipping Tracker (SHIPPING_TRACKER=self-hosted일 때)
# SHIPPING_TRACKER_URL=http://shipping.internal:8080
# SHIPPING_TRACKER_API_KEY=your-key

# Sync API 인증 (Vercel Cron용)
CRON_SECRET=your-cron-secret

# AI Recommendations (optional — falls back to rule-based)
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL_ID=claude-sonnet-4-20250514  # Override AI model (optional, default: claude-sonnet-4-20250514)

# Email (Resend)
RESEND_API_KEY=your-resend-key
RESEND_FROM_EMAIL=crew@banilaco.com
