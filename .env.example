# ============================================
# BANILACO SQUAD — Environment Variables
# ============================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/banilaco_squad

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Discord OAuth (NextAuth provider)
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Discord Bot
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=your-discord-guild-id

# TikTok Shop API
TIKTOK_SHOP_APP_KEY=your-app-key
TIKTOK_SHOP_APP_SECRET=your-app-secret
TIKTOK_SHOP_ID=your-shop-id
TIKTOK_SHOP_ACCESS_TOKEN=your-access-token

# Crawler — "apify" (default) or "self-hosted"
CRAWLER_TYPE=apify
APIFY_API_TOKEN=your-apify-token
# CRAWLER_BASE_URL=http://crawler.internal:8080

# Shipping Tracker
SHIPPING_TRACKER=aftership
AFTERSHIP_API_KEY=your-aftership-key
AFTERSHIP_WEBHOOK_SECRET=your-webhook-secret

# Sync API auth (Vercel Cron)
CRON_SECRET=your-cron-secret

# AI (Claude API — agent + recommendations + distiller)
ANTHROPIC_API_KEY=your-anthropic-key

# Email (Resend)
RESEND_API_KEY=your-resend-key
RESEND_FROM_EMAIL=squad@banilaco.com
